	<subDataset name="tableDataset" uuid="f13e6d36-5148-4ecc-bbe3-3035def80980">
		<queryString>
			<![CDATA[]]>
		</queryString>
	</subDataset>
	<queryString language="SQL">
		<![CDATA[SELECT 
    a.ID_Asistencia,
    a.Socio_ID,
    CONCAT(s.Nombre, ' ', s.Apellido1, ' ', IFNULL(s.Apellido2, '')) AS NombreCompleto,
    s.Nombre,
    s.Apellido1,
    s.Apellido2,
    s.DNI,
    s.Telefono,
    a.Fecha_Asistencia,
    a.Hora_entrada
FROM gym.asistencia a
INNER JOIN gym.socio s 
    ON a.Socio_ID = s.ID_Socio
ORDER BY 
    a.Fecha_Asistencia DESC,
    a.Hora_entrada DESC]]>
	</queryString>
