	<parameter name="Estado" class="java.lang.String"/>
	<parameter name="DNI" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT 
    p.ID_Pago,
    p.Socio_ID,
    p.Fecha_Pago,
    s.Nombre,
    s.Apellido1,
    s.Apellido2,
    s.DNI,
    p.Importe,
    p.Estado
FROM pago p
INNER JOIN socio s 
    ON p.Socio_ID = s.ID_Socio
WHERE 
    s.DNI = $P{DNI}
    AND p.Estado = $P{Estado}
ORDER BY 
    s.Apellido1 DESC,
    s.Apellido2 DESC,
    s.Nombre DESC,
    p.Fecha_Pago DESC]]>
	</queryString>
