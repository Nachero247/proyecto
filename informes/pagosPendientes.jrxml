	<queryString language="SQL">
		<![CDATA[SELECT 
    p.`ID_Pago`,
    p.`Socio_ID`,
    p.`Fecha_Pago`,
    s.`Nombre`,
    s.`Apellido1`,
    s.`Apellido2`,
    s.`DNI`,
    p.`Importe`,
    p.`Estado`
FROM gym.pago AS p
INNER JOIN gym.socio AS s
    ON p.`Socio_ID` = s.`ID_Socio`
WHERE p.`Estado` = 'Pendiente';]]>
	</queryString>
